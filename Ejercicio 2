#JAVA#
public class Operaciones {
    public static double calcSuma(double x, double y, double suma) { 
        suma = suma + x;
        x = x + (y*y);
        suma = suma + (x / y);
        return suma;
    }
    public static void main(String[] args) {
        double suma = 0;
        double x = 20;
        double y = 40;
        suma = calcSuma(x, y, suma);
        System.out.println("La suma es: " + suma);
    }
}
